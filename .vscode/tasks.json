{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "run-backend",
      "type": "shell",
      "isBackground": true,
      "windows": {
        "command": "cmd",
        "args": ["/c", "cmd /k dotnet watch run"]
      },
      "linux": {
        "command": "bash",
        "args": ["-c", "dotnet watch run"]
      },
      "osx": {
        "command": "bash",
        "args": ["-c", "dotnet watch run"]
      },
      "options": {
        "cwd": "${workspaceFolder}/backend/MyBackend"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "watching",
          "endsPattern": "Now listening on"
        }
      }
    },
    {
      "label": "run-frontend",
      "type": "shell",
      "isBackground": true,
      "windows": {
        "command": "cmd",
        "args": ["/c", "cmd /k npm run dev"]
      },
      "linux": {
        "command": "bash",
        "args": ["-c", "npm run dev"]
      },
      "osx": {
        "command": "bash",
        "args": ["-c", "npm run dev"]
      },
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": {
        "pattern": {
          "regexp": "."
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "VITE",
          "endsPattern": "ready in"
        }
      }
    },
    {
      "label": "prepare-dev-services",
      "type": "shell",
      "windows": {
        "command": "cmd",
        "args": ["/c", "timeout /t 2 >nul && npx wait-on tcp:localhost:5050 tcp:localhost:5173"]
      },
      "linux": {
        "command": "bash",
        "args": ["-c", "sleep 2 && npx wait-on tcp:localhost:5050 tcp:localhost:5173"]
      },
      "osx": {
        "command": "bash",
        "args": ["-c", "sleep 2 && npx wait-on tcp:localhost:5050 tcp:localhost:5173"]
      },
      "options": {
        "cwd": "${workspaceFolder}/desktop"
      },
      "dependsOn": [
        "run-backend",
        "run-frontend"
      ],
      "dependsOrder": "parallel",
      "problemMatcher": []
    }
  ]
}